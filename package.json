{
  "name": "creator-platform",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "build:web": "npm run build --workspace=web",
    "dev:api": "npm run start:dev --workspace=api",
    "build:api": "npm run build --workspace=api",
    "dev": "concurrently -n \"API,WEB\" -c \"blue,green\" \"npm run dev:api\" \"npm run dev:web\" \"wait-on http://localhost:3000 && start http://localhost:3000\"",
    "create-admin": "tsx scripts/create-admin-user.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "concurrently": "^9.2.1",
    "prisma": "^6.19.0",
    "tsx": "^4.21.0",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.555.0"
  }
}
